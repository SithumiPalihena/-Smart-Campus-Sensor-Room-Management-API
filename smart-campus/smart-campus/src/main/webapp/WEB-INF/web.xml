<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Smart Campus API</display-name>

    <!--
        Register Jersey as a servlet.
        Jersey's ServletContainer reads the init-param to discover all
        JAX-RS resources, providers, and filters via package scanning.
    -->
    <servlet>
        <servlet-name>JerseyServlet</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>

        <!-- Tell Jersey which package to scan for @Path, @Provider, etc. -->
        <init-param>
            <param-name>jersey.config.server.provider.packages</param-name>
            <param-value>com.smartcampus</param-value>
        </init-param>

        <!-- Ensure Jackson is used for JSON serialisation -->
        <init-param>
            <param-name>jersey.config.server.provider.classnames</param-name>
            <param-value>org.glassfish.jersey.jackson.JacksonFeature</param-value>
        </init-param>

        <!-- Start Jersey eagerly when Tomcat boots, not on first request -->
        <load-on-startup>1</load-on-startup>
    </servlet>

    <!--
        Map the servlet to /api/v1/*.
        Combined with ROOT.war (context path = /), every endpoint is at:
        http://localhost:8080/api/v1/...
    -->
    <servlet-mapping>
        <servlet-name>JerseyServlet</servlet-name>
        <url-pattern>/api/v1/*</url-pattern>
    </servlet-mapping>

</web-app>
